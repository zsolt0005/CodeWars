{
    "name": "zsolt/code-wars",
    "description": "Code wars practice",
    "type": "project",
    "authors": [
        {
            "name": "Zsolt Döme",
            "email": "zsoltdome0005@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5.3",
        "phpstan/phpstan": "^1.10.50"
    },
    "autoload": {
        "psr-4": {
            "Zsolt\\CodeWars\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Zsolt\\CodeWars\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "phpstan": "vendor/bin/phpstan analyse -c tests/PhpStan/phpstan.neon src/ tests/",
        "phpunit": "vendor/bin/phpunit tests/PhpUnit"
    }
}
